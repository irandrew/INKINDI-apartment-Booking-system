{
  "entities": {
    "apartment": {
      "title": "Apartment",
      "description": "Information about an apartment available for booking",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "pricePerNight": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "capacity": { "type": "number" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "cancellationPolicy": { "type": "string" }
      },
      "required": ["name", "pricePerNight", "location"]
    },
    "booking": {
      "title": "Booking",
      "description": "A guest's booking for an apartment",
      "type": "object",
      "properties": {
        "apartmentId": { "type": "string" },
        "guestUid": { "type": "string" },
        "guestName": { "type": "string" },
        "guestEmail": { "type": "string" },
        "guestPhone": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "stripeSessionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["apartmentId", "guestName", "guestEmail", "startDate", "endDate", "totalPrice", "paymentStatus"]
    },
    "user": {
      "title": "User Profile",
      "description": "Information about a user and their role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "property_manager", "guest"] }
      },
      "required": ["uid", "email", "role"]
    },
    "review": {
      "title": "Review",
      "description": "User reviews for apartments.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "comment", "createdAt"]
    },
    "favorite": {
      "title": "Favorite",
      "description": "An apartment saved by a user to their favorites list",
      "type": "object",
      "properties": {
        "apartmentId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["apartmentId", "userId", "createdAt"]
    }
  },
  "firestore": {
    "apartments": {
      "schema": "apartment",
      "description": "Collection of apartments"
    },
    "apartments/{apartmentId}/reviews": {
      "schema": "review",
      "description": "Subcollection of reviews for a specific apartment"
    },
    "bookings": {
      "schema": "booking",
      "description": "Collection of bookings"
    },
    "users": {
      "schema": "user",
      "description": "Collection of user profiles"
    },
    "users/{userId}/favorites": {
      "schema": "favorite",
      "description": "Subcollection of favorite apartments for a user"
    }
  }
}
