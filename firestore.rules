rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Role helpers - using a safer check that avoids recursion for self-profile access
    function isSuperAdmin() {
      return isSignedIn() && getUserData().role == 'super_admin';
    }

    function isPropertyManager() {
      return isSignedIn() && getUserData().role == 'property_manager';
    }

    function isAdmin() {
      let role = getUserData().role;
      return role == 'super_admin' || role == 'property_manager';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidApartment(data) {
      return data.keys().hasAll(['name', 'pricePerNight', 'location']) &&
             data.name is string && data.name.size() <= 200 &&
             data.pricePerNight is number &&
             data.location is string &&
             (!('cancellationPolicy' in data) || (data.cancellationPolicy is string && data.cancellationPolicy.size() <= 1000));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 5000 &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    // Apartments: Everyone can read, admins can manage
    match /apartments/{apartmentId} {
      allow read: if true;
      allow create: if isAdmin() && isValidApartment(incoming());
      allow update: if isAdmin() && isValidApartment(incoming());
      allow delete: if isAdmin();

      // Reviews subcollection
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidReview(incoming());
        allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      }
    }

    // Bookings: Guests can create, owners and admins can read
    match /bookings/{bookingId} {
      allow create: if true;
      allow get: if isAdmin() || (isSignedIn() && existing().guestUid == request.auth.uid);
      allow list: if isAdmin(); // Strictly enforce listing to admins only
      allow update, delete: if isAdmin();
    }

    // Users: Profiles and roles
    match /users/{userId} {
      // Accessing own profile
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Super admin can read any profile and list all
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';

      allow create: if isSignedIn() && request.auth.uid == userId && (
        incoming().role == 'guest' || 
        (request.auth.token.email == 'admin@inkindi.com' && incoming().role == 'super_admin')
      );
      
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email'])) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin')
      );

      // Favorites subcollection
      match /favorites/{apartmentId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
